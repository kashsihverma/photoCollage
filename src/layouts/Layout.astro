---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Photo Collage Maker | photocollagemake.com',
	description = 'Create and download clean photo collages from multiple uploaded images.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#fafafa" />
		<link rel="canonical" href="https://photocollagemake.com/" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://photocollagemake.com/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
