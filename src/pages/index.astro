---
import Layout from '../layouts/Layout.astro';

import copyIcon from 'lucide-static/icons/copy.svg?raw';
import downloadIcon from 'lucide-static/icons/download.svg?raw';
import imagesIcon from 'lucide-static/icons/images.svg?raw';
import layersIcon from 'lucide-static/icons/layers-3.svg?raw';
import layoutIcon from 'lucide-static/icons/layout-template.svg?raw';
import moonIcon from 'lucide-static/icons/moon.svg?raw';
import paletteIcon from 'lucide-static/icons/palette.svg?raw';
import pencilIcon from 'lucide-static/icons/pencil.svg?raw';
import redoIcon from 'lucide-static/icons/redo-2.svg?raw';
import saveIcon from 'lucide-static/icons/save.svg?raw';
import shareIcon from 'lucide-static/icons/share-2.svg?raw';
import shapesIcon from 'lucide-static/icons/shapes.svg?raw';
import sparklesIcon from 'lucide-static/icons/sparkles.svg?raw';
import sunIcon from 'lucide-static/icons/sun.svg?raw';
import textIcon from 'lucide-static/icons/type.svg?raw';
import trashIcon from 'lucide-static/icons/trash-2.svg?raw';
import undoIcon from 'lucide-static/icons/undo-2.svg?raw';
import uploadIcon from 'lucide-static/icons/upload.svg?raw';

const pageTitle = 'Free Online Photo Collage Maker | No Account, Browser Based';
const pageDescription =
	'Make photo collages online for Instagram, mood boards, birthdays, travel, products, and print. No account required, browser-based editing, PNG/JPG export.';
const canonical = 'https://onlinephotocollage.com/';
const seoKeywords = [
	'instagram collage',
	'instagram collage maker',
	'instagram collage story',
	'instagram collage post',
	'photo collage',
	'best photo collage apps',
	'photo collage maker',
	'photo collage app',
	'how to make a photo collage on iphone',
	'canvas photo collage',
	'photo collage canvas',
	'photo collage online free',
	'free photo collage app',
	'how to make a photo collage',
	'photo collage frame',
	'free photo collage',
	'photo collage template',
	'photo collage ideas',
	'free photo collage maker',
	'canva photo collage',
	'create photo collage',
	'photo collage maker free',
	'photo collage on canvas',
	'free online photo collage maker',
	'online photo collage maker',
	'online photo collage',
	'free online photo collage',
].join(', ');
const faqItems = [
	{
		question: 'How to make a collage on Instagram story?',
		answer:
			'Open the editor, choose a vertical Instagram story size, upload your photos, and pick a collage template. Replace the placeholder images, adjust frames and text, then download the finished story image and upload it to Instagram.',
	},
	{
		question: 'How to make a collage on Instagram?',
		answer:
			'Start with an Instagram-friendly canvas, add your photos, and arrange them with a template or custom layout. You can use frames, stickers, captions, and backgrounds before exporting the collage as a PNG or JPG for Instagram.',
	},
	{
		question: 'How to make a photo collage on iPhone?',
		answer:
			'On iPhone, open this website in Safari, upload images from Photos, choose a collage template, and edit the layout directly in the browser. When the design is ready, tap Download and save the image to your device.',
	},
	{
		question: 'How to make a photo collage?',
		answer:
			'To make a photo collage, upload multiple images, choose a layout, place the best photo as the focus, and arrange supporting photos around it. Add text, adjust spacing, and export the final collage for sharing or printing.',
	},
	{
		question: 'How to make a collage on Facebook cover photo?',
		answer:
			'Create a wide collage layout, place important faces and text near the center, and avoid putting key details at the edges. Export the design, then upload it as your Facebook cover photo and preview it on desktop and mobile.',
	},
	{
		question: 'How to make a photo collage on Android?',
		answer:
			'On Android, open the site in Chrome, upload photos from your gallery, select a template, and edit the collage in the browser. Download the final image when you are ready to share it on Instagram, Facebook, or messaging apps.',
	},
	{
		question: 'What is a photo collage?',
		answer:
			'A photo collage is a single design made from multiple photos arranged together. It can use frames, grids, overlapping layers, text, stickers, and backgrounds to tell a story or present a group of images in one shareable file.',
	},
];
const seoJsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebApplication',
			name: 'Photo Collage Maker',
			url: canonical,
			applicationCategory: 'MultimediaApplication',
			operatingSystem: 'Web',
			isAccessibleForFree: true,
			description: pageDescription,
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'USD',
			},
			featureList: [
				'Instagram collage maker',
				'Instagram collage story templates',
				'Instagram collage post templates',
				'Free online photo collage maker',
				'Photo collage templates and frames',
				'Canvas photo collage layouts',
				'PNG and JPG export',
				'Browser-based photo collage app',
			],
			publisher: {
				'@type': 'Organization',
				name: 'OnlinePhotoCollage.com',
				url: canonical,
			},
		},
		{
			'@type': 'FAQPage',
			mainEntity: faqItems.map((item) => ({
				'@type': 'Question',
				name: item.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: item.answer,
				},
			})),
		},
	],
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical={canonical}
	keywords={seoKeywords}
	image="/Icons/web-app-manifest-512x512.png"
	imageAlt="Photo Collage Maker official app icon"
	jsonLd={seoJsonLd}
>
	<header class="pc-topbar">
		<div class="pc-brand-group">
			<a href="/" class="pc-brand" aria-label="Photo Collage home">
				<span class="pc-brand-mark">
					<img src="/Icons/favicon.svg" alt="" width="30" height="30" loading="eager" decoding="async" />
				</span>
				<span>Photo Collage</span>
			</a>
			<button id="open-templates" class="pc-button pc-button-secondary pc-templates-button" type="button">
				<span class="pc-icon" set:html={layoutIcon} aria-hidden="true"></span>
				Templates
			</button>
		</div>

		<div class="pc-toolbar" aria-label="Editor toolbar">
			<button id="undo-action" class="pc-tool-button" type="button" aria-label="Undo">
				<span class="pc-icon" set:html={undoIcon} aria-hidden="true"></span>
			</button>
			<button id="redo-action" class="pc-tool-button" type="button" aria-label="Redo">
				<span class="pc-icon" set:html={redoIcon} aria-hidden="true"></span>
			</button>
			<span class="pc-toolbar-divider" aria-hidden="true"></span>
			<select id="size-select" class="pc-select" aria-label="Export size"></select>
			<select id="format-select" class="pc-select" aria-label="Export format">
				<option value="png">PNG</option>
				<option value="jpeg">JPG</option>
			</select>
			</div>

			<div class="pc-top-actions">
				<button id="theme-toggle" class="pc-button pc-button-secondary pc-theme-toggle" type="button" aria-label="Switch to dark mode" aria-pressed="false">
					<span class="pc-icon pc-theme-icon pc-theme-icon-moon" set:html={moonIcon} aria-hidden="true"></span>
					<span class="pc-icon pc-theme-icon pc-theme-icon-sun" set:html={sunIcon} aria-hidden="true"></span>
					<span class="pc-theme-label">Dark</span>
				</button>
				<button id="save-design" class="pc-button pc-button-secondary" type="button">
					<span class="pc-icon" set:html={saveIcon} aria-hidden="true"></span>
					Save
				</button>
				<button id="share-collage" class="pc-button pc-button-secondary" type="button" aria-controls="share-panel" aria-expanded="false">
					<span class="pc-icon" set:html={shareIcon} aria-hidden="true"></span>
					Share
				</button>
				<button id="finish-collage" class="pc-button pc-button-primary" type="button">
					<span class="pc-icon" set:html={downloadIcon} aria-hidden="true"></span>
					Download
				</button>
			</div>
	</header>

	<main class="pc-page-main">
	<section id="studio" class="pc-editor-app" aria-label="Photo collage editor">
		<aside class="pc-sidebar" aria-label="Editor panels">
			<nav class="pc-panel-tabs" aria-label="Tools">
				<button class="pc-panel-tab" type="button" data-panel="templates" aria-pressed="true" title="Templates">
					<span class="pc-icon" set:html={layoutIcon} aria-hidden="true"></span>
					<span>Templates</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="uploads" aria-pressed="false" title="Uploads">
					<span class="pc-icon" set:html={imagesIcon} aria-hidden="true"></span>
					<span>Photos</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="text" aria-pressed="false" title="Text">
					<span class="pc-icon" set:html={textIcon} aria-hidden="true"></span>
					<span>Text</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="elements" aria-pressed="false" title="Elements">
					<span class="pc-icon" set:html={shapesIcon} aria-hidden="true"></span>
					<span>Elements</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="backgrounds" aria-pressed="false" title="Backgrounds">
					<span class="pc-icon" set:html={paletteIcon} aria-hidden="true"></span>
					<span>Canvas</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="layers" aria-pressed="false" title="Layers">
					<span class="pc-icon" set:html={layersIcon} aria-hidden="true"></span>
					<span>Layers</span>
				</button>
			</nav>

			<div class="pc-panel-browser">
				<section class="pc-panel-view" data-panel-view="templates" aria-labelledby="templates-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Gallery</p>
							<h2 id="templates-title">Templates</h2>
						</div>
					</div>
					<div id="category-list" class="pc-category-list" aria-label="Template categories"></div>
					<label class="pc-template-size-toggle">
						<span>Show templates with the same size</span>
						<input type="checkbox" checked />
					</label>
					<div id="template-list" class="pc-template-gallery" aria-live="polite"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="uploads" aria-labelledby="upload-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Photos</p>
							<h2 id="upload-title">Uploads</h2>
						</div>
						<p id="photo-count" class="pc-count">0 photos</p>
					</div>

					<label id="drop-zone" for="photo-input" class="pc-drop-zone">
						<span class="pc-drop-icon">
							<span class="pc-icon" set:html={uploadIcon} aria-hidden="true"></span>
						</span>
						<span>Drop photos</span>
						<small>PNG, JPG, WebP, AVIF</small>
						<input id="photo-input" class="sr-only" type="file" accept="image/*" multiple />
					</label>

					<div class="pc-smart-panel" aria-label="Smart collage layouts">
						<div>
							<p class="pc-label">Smart start</p>
							<h3>Generate layouts from uploads</h3>
						</div>
						<div class="pc-smart-actions">
							<button id="smart-balanced" class="pc-button pc-button-secondary" type="button">Balanced</button>
							<button id="smart-story" class="pc-button pc-button-secondary" type="button">Story</button>
							<button id="smart-moodboard" class="pc-button pc-button-secondary" type="button">Moodboard</button>
						</div>
					</div>

					<div class="pc-inline-actions">
						<button id="clear-photos" class="pc-button pc-button-secondary pc-delete-all" type="button" aria-label="Delete all uploaded photos">
							<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
							Delete all
						</button>
					</div>

					<div id="photo-tray" class="pc-upload-grid" aria-live="polite"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="text" aria-labelledby="text-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Typography</p>
							<h2 id="text-title">Text</h2>
						</div>
						<span class="pc-icon text-body" set:html={textIcon} aria-hidden="true"></span>
					</div>
					<button id="add-text" class="pc-button pc-button-primary w-full" type="button">
						<span class="pc-icon" set:html={textIcon} aria-hidden="true"></span>
						Add text
					</button>
					<div id="text-preset-list" class="pc-preset-list"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="elements" aria-labelledby="elements-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Decor</p>
							<h2 id="elements-title">Elements</h2>
						</div>
						<span class="pc-icon text-body" set:html={sparklesIcon} aria-hidden="true"></span>
					</div>
					<div id="element-list" class="pc-element-grid"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="backgrounds" aria-labelledby="backgrounds-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Canvas</p>
							<h2 id="backgrounds-title">Backgrounds</h2>
						</div>
						<span class="pc-icon text-body" set:html={paletteIcon} aria-hidden="true"></span>
					</div>
					<div class="pc-background-photo-panel">
						<div class="pc-background-actions">
							<button id="add-background-photo" class="pc-button pc-button-secondary" type="button">
								<span class="pc-icon" set:html={uploadIcon} aria-hidden="true"></span>
								Upload photo
							</button>
							<button id="clear-background-photo" class="pc-icon-button" type="button" aria-label="Clear background photo">
								<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
							</button>
						</div>
						<input id="background-photo-input" class="sr-only" type="file" accept="image/*" multiple />
						<div id="background-photo-list" class="pc-background-photo-grid"></div>
					</div>
					<label class="pc-background-tone pc-field">
						<span class="pc-field-row">
							<span>Background tone</span>
							<span id="background-tone-value">Normal</span>
						</span>
						<input id="background-tone-control" type="range" min="0" max="100" step="1" value="50" />
					</label>
					<div id="background-list" class="pc-background-grid"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="layers" aria-labelledby="layers-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Objects</p>
							<h2 id="layers-title">Layers</h2>
						</div>
						<span class="pc-icon text-body" set:html={layersIcon} aria-hidden="true"></span>
					</div>
					<div id="layer-list" class="pc-layer-list"></div>
				</section>
			</div>
		</aside>

		<section class="pc-workspace" aria-labelledby="preview-title">
			<div class="pc-workspace-header">
				<div>
					<p class="pc-label">Canvas</p>
					<h2 id="preview-title">Editor</h2>
				</div>
				<div class="pc-active-meta">
					<span id="active-template-label">Love Polaroids</span>
					<span aria-hidden="true">/</span>
					<span id="active-size-label">Instagram post</span>
				</div>
			</div>

			<div id="editor-stage" class="pc-stage">
				<div id="snap-guide-x" class="pc-guide pc-guide-x hidden" aria-hidden="true"></div>
				<div id="snap-guide-y" class="pc-guide pc-guide-y hidden" aria-hidden="true"></div>
				<div id="collage-preview" class="pc-design-surface" aria-label="Editable collage canvas"></div>
			</div>

				<div class="pc-statusbar">
					<p id="status-line" aria-live="polite">Choose a template or upload photos.</p>
					<div id="download-panel" class="pc-download-panel hidden">
						<canvas id="export-canvas" class="hidden"></canvas>
						<a id="download-link" class="pc-button pc-button-primary" href="#" download="photo-collage.png">
							<span class="pc-icon" set:html={downloadIcon} aria-hidden="true"></span>
							Download ready
						</a>
					</div>
					<div id="share-panel" class="pc-share-panel hidden" aria-label="Share collage options">
						<div class="pc-share-panel-heading">
								<div>
									<strong>Share collage</strong>
									<span>Works on desktop web and phone.</span>
								</div>
								<button id="share-close" class="pc-share-close" type="button" aria-label="Close share options">x</button>
							</div>
							<div class="pc-share-options">
								<button class="pc-share-option" type="button" data-share-target="native">
									<strong>Share to apps</strong>
									<span>Instagram, Stories, Snapchat, Messages</span>
								</button>
								<button class="pc-share-option" type="button" data-share-target="copy">
									<strong>Copy image</strong>
									<span>Paste into chats or web apps</span>
								</button>
								<button class="pc-share-option" type="button" data-share-target="whatsapp">
									<strong>WhatsApp / Web</strong>
									<span>Copy or download, then open WhatsApp</span>
								</button>
								<button class="pc-share-option" type="button" data-share-target="instagram">
									<strong>Instagram post/story</strong>
									<span>Share on phone or upload on web</span>
								</button>
								<button class="pc-share-option" type="button" data-share-target="snapchat">
									<strong>Snapchat</strong>
									<span>Share on phone or upload on web</span>
								</button>
							<button class="pc-share-option" type="button" data-share-target="download">
								<strong>Download image</strong>
								<span>Upload anywhere manually</span>
							</button>
						</div>
					</div>
					<p id="export-empty" class="sr-only">Download the collage from the top toolbar.</p>
				</div>
		</section>

		<aside class="pc-inspector" aria-label="Selected object controls">
			<div class="pc-inspector-heading">
				<div>
					<p class="pc-label">Selection</p>
					<h2>Adjust</h2>
				</div>
				<div class="pc-inline-actions">
					<button id="duplicate-layer" class="pc-icon-button" type="button" aria-label="Duplicate selected object">
						<span class="pc-icon" set:html={copyIcon} aria-hidden="true"></span>
					</button>
					<button id="delete-layer" class="pc-icon-button" type="button" aria-label="Delete selected object">
						<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
					</button>
				</div>
			</div>
			<div id="inspector-panel" class="pc-inspector-panel"></div>
		</aside>
	</section>

	<section class="pc-seo-section" aria-labelledby="seo-title">
		<article class="pc-seo-content">
			<div class="pc-seo-heading">
				<p class="pc-label">Free online editor</p>
				<h1 id="seo-title">Privacy-First Online Photo Collage Maker</h1>
				<p class="pc-seo-lede">
					Create collages for Instagram, mood boards, birthdays, travel, products, and print. Start with templates or upload photos, generate a smart layout, refine every layer, and download a polished PNG or JPG.
				</p>
			</div>

			<div class="pc-seo-grid">
				<div class="pc-seo-copy">
					<p>
						An Instagram collage should be fast to make, easy to adjust, and sharp enough to post without extra cleanup. This Instagram collage maker opens directly into the editor, so you can upload photos, choose a layout, adjust the canvas, and download a finished image without setting up a full design project. It is built for creators, small businesses, students, families, and anyone who wants to turn several photos into one polished Instagram collage. The workspace keeps the core tools close: templates on the left, the editable canvas in the center, and object controls on the right.
					</p>
					<p>
						Use the tool when you need an Instagram collage story for a birthday recap, travel diary, product launch, outfit board, client mood board, or day-in-the-life update. Story layouts need a vertical canvas, clear spacing, and text that stays readable on a phone. The editor includes vertical sizes, drag-and-drop photo frames, background options, stickers, and typography presets so you can build an Instagram collage story that feels organized rather than crowded. Upload your images, pick a template, replace the placeholders, and move each layer until the story frame looks balanced.
					</p>
					<p>
						For feed content, start with an Instagram collage post size and keep the composition simple. An Instagram collage post often works best when one image is the hero and the supporting photos add context around it. You can create product before-and-after posts, event highlights, portfolio samples, family memories, wedding previews, restaurant menus, or carousel cover images. The editor supports square and portrait-friendly sizes, so you can create a clean Instagram collage post and export it as a PNG or JPG for publishing.
					</p>
					<p>
						A useful collage tool should give you more control than a basic camera roll grid while staying lighter than a full design suite. This free online editor lets you resize frames, change backgrounds, add text, duplicate objects, remove layers, and save your design in the browser. You can use photo collage templates as a starting point, then customize the images, captions, colors, and decorative elements for your own Instagram style. The goal is not to copy a social media template exactly; it is to help you create a layout that feels personal and ready to share.
					</p>
					<p>
						If you are making content on iPhone, open the site in Safari, upload images from Photos, choose an Instagram collage story or post template, and tap Download when the design is finished. On desktop, you get more room for detailed edits, layer selection, and text adjustments. Both workflows are useful: mobile is quick for casual stories, while desktop is comfortable for brand posts, campaign visuals, and larger batches of images. Because the editor runs online, it can work as a focused Instagram collage app without requiring an app store install.
					</p>
					<p>
						The best Instagram collage designs usually follow a few simple rules. Start with the strongest photo, keep supporting images visually related, leave breathing room between frames, and use short captions instead of long paragraphs. Match the background to the feeling of the post: soft colors for memories, clean white space for portfolios, bold accents for launches, and playful stickers for celebrations. The editor gives you room to test several Instagram collage ideas quickly, including tight grids, layered scrapbook looks, clean editorial layouts, and story-ready vertical designs.
					</p>
					<p>
						This tool is also helpful when you want a photo collage for Instagram but do not want a broad platform with too many unrelated options. It focuses on collage creation, export quality, and a clean workflow. You can make an Instagram collage maker free project for a story, post, announcement, highlight cover, or quick memory page, then download the final image and publish it wherever you manage your social content. The result is a practical, lightweight way to create Instagram collage visuals online.
					</p>
				</div>

				<aside class="pc-seo-aside" aria-label="Instagram collage use cases">
					<h2>Popular collage makers</h2>
					<ul>
						<li><a href="/instagram-collage-maker/">Instagram collage maker</a></li>
						<li><a href="/mood-board-maker/">Mood board maker</a></li>
						<li><a href="/birthday-photo-collage/">Birthday photo collage maker</a></li>
						<li><a href="/travel-photo-collage/">Travel photo collage maker</a></li>
						<li><a href="/facebook-cover-collage/">Facebook cover collage maker</a></li>
						<li><a href="/printable-photo-collage/">Printable photo collage maker</a></li>
					</ul>
				</aside>
			</div>

			<section class="pc-faq" aria-labelledby="faq-title">
				<div class="pc-faq-heading">
					<p class="pc-label">FAQ</p>
					<h2 id="faq-title">Photo Collage Questions</h2>
					<p>Quick answers for making Instagram collages, iPhone collages, Android collages, Facebook cover collages, and general photo collage designs.</p>
				</div>

				<div class="pc-faq-list">
					{faqItems.map((item) => (
						<details class="pc-faq-item">
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))}
				</div>
			</section>
		</article>
	</section>

	<footer class="pc-site-footer" aria-label="Website links">
