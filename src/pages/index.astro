---
import Layout from '../layouts/Layout.astro';

import copyIcon from 'lucide-static/icons/copy.svg?raw';
import downloadIcon from 'lucide-static/icons/download.svg?raw';
import imagesIcon from 'lucide-static/icons/images.svg?raw';
import layersIcon from 'lucide-static/icons/layers-3.svg?raw';
import layoutIcon from 'lucide-static/icons/layout-template.svg?raw';
import moonIcon from 'lucide-static/icons/moon.svg?raw';
import paletteIcon from 'lucide-static/icons/palette.svg?raw';
import redoIcon from 'lucide-static/icons/redo-2.svg?raw';
import saveIcon from 'lucide-static/icons/save.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import shapesIcon from 'lucide-static/icons/shapes.svg?raw';
import sparklesIcon from 'lucide-static/icons/sparkles.svg?raw';
import sunIcon from 'lucide-static/icons/sun.svg?raw';
import textIcon from 'lucide-static/icons/type.svg?raw';
import trashIcon from 'lucide-static/icons/trash-2.svg?raw';
import undoIcon from 'lucide-static/icons/undo-2.svg?raw';
import uploadIcon from 'lucide-static/icons/upload.svg?raw';
---

<Layout
	title="Photo Collage Maker | Premium collage editor"
	description="Create premium photo collages with templates, photos, text, stickers, frames, backgrounds, and high-resolution PNG or JPG export."
>
	<header class="pc-topbar">
		<a href="/" class="pc-brand" aria-label="Photo Collage home">
			<span class="pc-brand-mark">
				<img src="/Icons/favicon.svg" alt="" width="30" height="30" loading="eager" decoding="async" />
			</span>
			<span>Photo Collage</span>
		</a>

		<div class="pc-toolbar" aria-label="Editor toolbar">
			<button id="undo-action" class="pc-tool-button" type="button" aria-label="Undo">
				<span class="pc-icon" set:html={undoIcon} aria-hidden="true"></span>
			</button>
			<button id="redo-action" class="pc-tool-button" type="button" aria-label="Redo">
				<span class="pc-icon" set:html={redoIcon} aria-hidden="true"></span>
			</button>
			<span class="pc-toolbar-divider" aria-hidden="true"></span>
			<select id="size-select" class="pc-select" aria-label="Export size"></select>
			<select id="format-select" class="pc-select" aria-label="Export format">
				<option value="png">PNG</option>
				<option value="jpeg">JPG</option>
			</select>
		</div>

		<div class="pc-top-actions">
			<button id="theme-toggle" class="pc-button pc-button-secondary pc-theme-toggle" type="button" aria-label="Switch to dark mode" aria-pressed="false">
				<span class="pc-icon pc-theme-icon pc-theme-icon-moon" set:html={moonIcon} aria-hidden="true"></span>
				<span class="pc-icon pc-theme-icon pc-theme-icon-sun" set:html={sunIcon} aria-hidden="true"></span>
				<span class="pc-theme-label">Dark</span>
			</button>
			<button id="save-design" class="pc-button pc-button-secondary" type="button">
				<span class="pc-icon" set:html={saveIcon} aria-hidden="true"></span>
				Save
			</button>
			<button id="finish-collage" class="pc-button pc-button-primary" type="button">
				<span class="pc-icon" set:html={downloadIcon} aria-hidden="true"></span>
				Download
			</button>
		</div>
	</header>

	<main id="studio" class="pc-editor-app">
		<aside class="pc-sidebar" aria-label="Editor panels">
			<nav class="pc-panel-tabs" aria-label="Tools">
				<button class="pc-panel-tab" type="button" data-panel="templates" aria-pressed="true" title="Templates">
					<span class="pc-icon" set:html={layoutIcon} aria-hidden="true"></span>
					<span>Templates</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="uploads" aria-pressed="false" title="Uploads">
					<span class="pc-icon" set:html={imagesIcon} aria-hidden="true"></span>
					<span>Photos</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="text" aria-pressed="false" title="Text">
					<span class="pc-icon" set:html={textIcon} aria-hidden="true"></span>
					<span>Text</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="elements" aria-pressed="false" title="Elements">
					<span class="pc-icon" set:html={shapesIcon} aria-hidden="true"></span>
					<span>Elements</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="backgrounds" aria-pressed="false" title="Backgrounds">
					<span class="pc-icon" set:html={paletteIcon} aria-hidden="true"></span>
					<span>Canvas</span>
				</button>
				<button class="pc-panel-tab" type="button" data-panel="layers" aria-pressed="false" title="Layers">
					<span class="pc-icon" set:html={layersIcon} aria-hidden="true"></span>
					<span>Layers</span>
				</button>
			</nav>

			<div class="pc-panel-browser">
				<label class="pc-panel-search">
					<span class="pc-icon" set:html={searchIcon} aria-hidden="true"></span>
					<input id="asset-search" type="search" autocomplete="off" placeholder="Search assets" aria-label="Search active panel" />
				</label>

				<section class="pc-panel-view" data-panel-view="templates" aria-labelledby="templates-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Gallery</p>
							<h1 id="templates-title">Templates</h1>
						</div>
					</div>
					<div id="category-list" class="pc-category-list" aria-label="Template categories"></div>
					<label class="pc-template-size-toggle">
						<span>Show templates with the same size</span>
						<input type="checkbox" checked />
					</label>
					<div id="template-list" class="pc-template-gallery" aria-live="polite"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="uploads" aria-labelledby="upload-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Photos</p>
							<h2 id="upload-title">Uploads</h2>
						</div>
						<p id="photo-count" class="pc-count">0 photos</p>
					</div>

					<label id="drop-zone" for="photo-input" class="pc-drop-zone">
						<span class="pc-drop-icon">
							<span class="pc-icon" set:html={uploadIcon} aria-hidden="true"></span>
						</span>
						<span>Drop photos</span>
						<small>PNG, JPG, WebP, AVIF</small>
						<input id="photo-input" class="sr-only" type="file" accept="image/*" multiple />
					</label>

					<div class="pc-inline-actions">
						<button id="clear-photos" class="pc-button pc-button-secondary pc-delete-all" type="button" aria-label="Delete all uploaded photos">
							<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
							Delete all
						</button>
					</div>

					<div id="photo-tray" class="pc-upload-grid" aria-live="polite"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="text" aria-labelledby="text-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Typography</p>
							<h2 id="text-title">Text</h2>
						</div>
						<span class="pc-icon text-body" set:html={textIcon} aria-hidden="true"></span>
					</div>
					<button id="add-text" class="pc-button pc-button-primary w-full" type="button">
						<span class="pc-icon" set:html={textIcon} aria-hidden="true"></span>
						Add text
					</button>
					<div id="text-preset-list" class="pc-preset-list"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="elements" aria-labelledby="elements-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Decor</p>
							<h2 id="elements-title">Elements</h2>
						</div>
						<span class="pc-icon text-body" set:html={sparklesIcon} aria-hidden="true"></span>
					</div>
					<div id="element-list" class="pc-element-grid"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="backgrounds" aria-labelledby="backgrounds-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Canvas</p>
							<h2 id="backgrounds-title">Backgrounds</h2>
						</div>
						<span class="pc-icon text-body" set:html={paletteIcon} aria-hidden="true"></span>
					</div>
					<div class="pc-background-photo-panel">
						<div class="pc-background-actions">
							<button id="add-background-photo" class="pc-button pc-button-secondary" type="button">
								<span class="pc-icon" set:html={uploadIcon} aria-hidden="true"></span>
								Upload photo
							</button>
							<button id="clear-background-photo" class="pc-icon-button" type="button" aria-label="Clear background photo">
								<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
							</button>
						</div>
						<input id="background-photo-input" class="sr-only" type="file" accept="image/*" multiple />
						<div id="background-photo-list" class="pc-background-photo-grid"></div>
					</div>
					<label class="pc-background-tone pc-field">
						<span class="pc-field-row">
							<span>Background tone</span>
							<span id="background-tone-value">Normal</span>
						</span>
						<input id="background-tone-control" type="range" min="0" max="100" step="1" value="50" />
					</label>
					<div id="background-list" class="pc-background-grid"></div>
				</section>

				<section class="pc-panel-view hidden" data-panel-view="layers" aria-labelledby="layers-title">
					<div class="pc-panel-heading">
						<div>
							<p class="pc-label">Objects</p>
							<h2 id="layers-title">Layers</h2>
						</div>
						<span class="pc-icon text-body" set:html={layersIcon} aria-hidden="true"></span>
					</div>
					<div id="layer-list" class="pc-layer-list"></div>
				</section>
			</div>
		</aside>

		<section class="pc-workspace" aria-labelledby="preview-title">
			<div class="pc-workspace-header">
				<div>
					<p class="pc-label">Canvas</p>
					<h2 id="preview-title">Editor</h2>
				</div>
				<div class="pc-active-meta">
					<span id="active-template-label">Love Polaroids</span>
					<span aria-hidden="true">/</span>
					<span id="active-size-label">Instagram post</span>
				</div>
			</div>

			<div id="editor-stage" class="pc-stage">
				<div id="snap-guide-x" class="pc-guide pc-guide-x hidden" aria-hidden="true"></div>
				<div id="snap-guide-y" class="pc-guide pc-guide-y hidden" aria-hidden="true"></div>
				<div id="collage-preview" class="pc-design-surface" aria-label="Editable collage canvas"></div>
			</div>

			<div class="pc-statusbar">
				<p id="status-line" aria-live="polite">Choose a template or upload photos.</p>
				<div id="download-panel" class="pc-download-panel hidden">
					<canvas id="export-canvas" class="hidden"></canvas>
					<a id="download-link" class="pc-button pc-button-primary" href="#" download="photo-collage.png">
						<span class="pc-icon" set:html={downloadIcon} aria-hidden="true"></span>
						Download ready
					</a>
				</div>
				<p id="export-empty" class="sr-only">Download the collage from the top toolbar.</p>
			</div>
		</section>

		<aside class="pc-inspector" aria-label="Selected object controls">
			<div class="pc-inspector-heading">
				<div>
					<p class="pc-label">Selection</p>
					<h2>Adjust</h2>
				</div>
				<div class="pc-inline-actions">
					<button id="duplicate-layer" class="pc-icon-button" type="button" aria-label="Duplicate selected object">
						<span class="pc-icon" set:html={copyIcon} aria-hidden="true"></span>
					</button>
					<button id="delete-layer" class="pc-icon-button" type="button" aria-label="Delete selected object">
						<span class="pc-icon" set:html={trashIcon} aria-hidden="true"></span>
					</button>
				</div>
			</div>
			<div id="inspector-panel" class="pc-inspector-panel"></div>
		</aside>
	</main>
</Layout>

<script>
	import '../scripts/collage-studio';
</script>
